{
  "name": "@umbeli-com/layout",
  "version": "1.0.0",
  "description": "Reusable layout components for Umbeli SaaS applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": {
      "types": "./styles.d.ts",
      "default": "./dist/styles/index.css"
    },
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist",
    "styles.d.ts"
  ],
  "scripts": {
    "build": "tsc && npm run build:styles",
    "build:styles": "sass src/styles:dist/styles --style=compressed",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@umbeli-com/ui": "workspace:^",
    "lucide-react": "^0.315.0",
    "react-ionicons": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "sass": "^1.70.0",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/umbeli-com/UmbeliumComponents.git",
    "directory": "packages/layout"
  },
  "license": "MIT"
}
