{
  "name": "@umbeli/billing",
  "version": "1.0.0",
  "description": "Billing and payment components for Umbeli SaaS applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/styles/index.css",
    "./styles/*": "./dist/styles/*",
    "./src/styles/*": "./src/styles/*",
    "./src/components/*": "./src/components/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc && npm run build:styles",
    "build:styles": "sass src/styles:dist/styles --style=compressed --silence-deprecation=import",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@umbeli/ui": "file:../ui",
    "@stripe/stripe-js": "^8.6.0",
    "@stripe/react-stripe-js": "^5.4.1",
    "lucide-react": "^0.315.0",
    "react-ionicons": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "sass": "^1.70.0",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/umbeli-com/UmbeliComponents.git",
    "directory": "packages/billing"
  },
  "license": "MIT"
}